rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function signInProvider() {
      return signedIn() && request.auth.token.firebase != null
        ? request.auth.token.firebase.sign_in_provider
        : '';
    }

    function trustedUser() {
      return signedIn() && signInProvider() != 'anonymous';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function userRecord() {
      return get(userPath(request.auth.uid));
    }

    function currentUserExists() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function hasCustomAdminClaim() {
      return signedIn()
        && (request.auth.token.admin == true
          || request.auth.token.superUser == true
          || request.auth.token.isSuperUser == true);
    }

    function isSuperUser() {
      return hasCustomAdminClaim()
        || (trustedUser()
          && currentUserExists()
          && userRecord().data.isSuperUser == true);
    }

    function hasPermission(permission) {
      return isSuperUser()
        || (trustedUser()
          && currentUserExists()
          && userRecord().data.roleId is string
          && exists(/databases/$(database)/documents/roles/$(userRecord().data.roleId))
          && get(/databases/$(database)/documents/roles/$(userRecord().data.roleId)).data.permissions.hasAny([permission]));
    }

    function allowedUserCreateFields() {
      return [
        'name', 'surname', 'displayName', 'email', 'phone', 'phoneCountryCode',
        'phoneComplete', 'isoCountryCode', 'photoUrl', 'ageRange', 'gender',
        'createdAt', 'lastLogin', 'hasSkippedBanner',
        'hasCompletedAdditionalFields', 'additionalFieldsLastUpdated',
        'lastBannerShown', 'neverShowBannerAgain', 'isVisitorOnly'
      ];
    }

    function allowedUserUpdateFields() {
      return [
        'name', 'surname', 'displayName', 'phone', 'phoneCountryCode',
        'phoneComplete', 'isoCountryCode', 'photoUrl', 'ageRange', 'gender',
        'lastLogin', 'hasSkippedBanner', 'hasCompletedAdditionalFields',
        'additionalFieldsLastUpdated', 'lastBannerShown',
        'neverShowBannerAgain', 'isVisitorOnly', 'fcmToken',
        'fcmTokenUpdatedAt', 'platform', 'paymentProfile'
      ];
    }

    function createsOwnUserDoc(userId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly(allowedUserCreateFields());
    }

    function updatesOwnUserDoc() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(allowedUserUpdateFields());
    }

    function publicRead() {
      return signedIn();
    }

    function adminOnly() {
      return hasPermission('manage_roles')
        || hasPermission('view_user_list')
        || hasPermission('manage_pages');
    }

    function canManageContent() {
      return hasPermission('manage_pages')
        || hasPermission('manage_announcements')
        || hasPermission('manage_cults')
        || hasPermission('manage_videos');
    }

    function ownNotification() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnNotification() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownPayment() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if createsOwnUserDoc(userId) || adminOnly();
      allow get: if isOwner(userId) || adminOnly();
      allow list: if adminOnly();
      allow update: if (isOwner(userId) && updatesOwnUserDoc()) || adminOnly();
      allow delete: if adminOnly();

      match /login_history/{historyId} {
        allow read, create: if isOwner(userId) || adminOnly();
        allow update, delete: if adminOnly();
      }

      match /savedLocations/{locationId} {
        allow read, write: if isOwner(userId) || adminOnly();
      }

      match /{privateDoc=**} {
        allow read, write: if isOwner(userId) || adminOnly();
      }
    }

    match /roles/{roleId} {
      allow read: if trustedUser();
      allow write: if hasPermission('manage_roles');
    }

    match /appConfig/{configId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_livestream_config')
        || hasPermission('manage_donations_config')
        || hasPermission('manage_pages');
    }

    match /finance_receivers/{receiverId} {
      allow read: if hasPermission('manage_finance_accounts')
        || hasPermission('manage_donation_payments')
        || hasPermission('manage_event_payments');
      allow write: if hasPermission('manage_finance_accounts');
    }

    match /payments/{paymentId} {
      allow read: if ownPayment()
        || hasPermission('manage_donation_payments')
        || hasPermission('manage_event_payments')
        || hasPermission('view_finance_reports');
      allow write: if false;
    }

    match /recurring_plans/{planId} {
      allow read: if hasPermission('manage_recurring_donations')
        || hasPermission('view_finance_reports');
      allow write: if false;
    }

    match /recurrence_plan_by_account/{accountId} {
      allow read: if hasPermission('manage_recurring_donations')
        || hasPermission('view_finance_reports');
      allow write: if false;
    }

    match /push_notifications_log/{logId} {
      allow read: if hasPermission('send_push_notifications');
      allow write: if false;
    }

    match /notifications/{notificationId} {
      allow read: if ownNotification() || adminOnly();
      allow create: if createsOwnNotification() || adminOnly();
      allow update: if ownNotification()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if ownNotification() || adminOnly();
    }

    match /events/{eventId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_event_attendance') || hasPermission('manage_cults');

      match /tickets/{ticketId} {
        allow read: if publicRead();
        allow write: if hasPermission('manage_event_payments') || hasPermission('manage_event_attendance');
      }

      match /registrations/{registrationId} {
        allow read: if signedIn()
          && (resource.data.userId == request.auth.uid || hasPermission('manage_event_attendance'));
        allow create: if false;
        allow update: if hasPermission('manage_event_attendance');
        allow delete: if signedIn()
          && (resource.data.userId == request.auth.uid || hasPermission('manage_event_attendance'));
      }

      match /online_attendance/{attendanceId} {
        allow read, create: if trustedUser();
        allow update, delete: if hasPermission('manage_event_attendance');
      }
    }

    match /groups/{groupId} {
      allow read: if publicRead();
      allow create: if hasPermission('create_group');
      allow update, delete: if hasPermission('create_group') || hasPermission('manage_groups');

      match /members/{userId} {
        allow read: if trustedUser();
        allow write: if false;
      }
    }

    match /ministries/{ministryId} {
      allow read: if publicRead();
      allow create: if hasPermission('create_ministry');
      allow update, delete: if hasPermission('create_ministry') || hasPermission('manage_ministries');

      match /members/{userId} {
        allow read: if trustedUser();
        allow write: if false;
      }
    }

    match /membership_requests/{requestId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid
          || hasPermission('create_group')
          || hasPermission('create_ministry'));
      allow create: if trustedUser() && request.resource.data.userId == request.auth.uid;
      allow update: if hasPermission('create_group') || hasPermission('create_ministry');
      allow delete: if adminOnly();
    }

    match /member_exits/{exitId} {
      allow read: if adminOnly() || hasPermission('view_group_stats') || hasPermission('view_ministry_stats');
      allow create: if trustedUser();
      allow update, delete: if adminOnly();
    }

    match /group_chat_messages/{messageId} {
      allow read: if publicRead();
      allow create: if trustedUser()
        && request.resource.data.authorId == userPath(request.auth.uid);
      allow update: if signedIn()
        && (resource.data.authorId == userPath(request.auth.uid) || adminOnly())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'content', 'fileUrl', 'fileName', 'fileType']);
      allow delete: if adminOnly();
    }

    match /ministry_chat_messages/{messageId} {
      allow read: if publicRead();
      allow create: if trustedUser()
        && request.resource.data.authorId == userPath(request.auth.uid);
      allow update: if signedIn()
        && (resource.data.authorId == userPath(request.auth.uid) || adminOnly())
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isDeleted', 'content', 'fileUrl', 'fileName', 'fileType']);
      allow delete: if adminOnly();
    }

    match /group_posts/{postId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.authorId == userPath(request.auth.uid);
    }

    match /ministry_posts/{postId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.authorId == userPath(request.auth.uid);
    }

    match /comments/{commentId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.authorId == userPath(request.auth.uid);
    }

    match /group_comments/{commentId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.authorId == userPath(request.auth.uid);
    }

    match /group_post_comments/{commentId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.authorId == userPath(request.auth.uid);
    }

    match /prayer_comments/{commentId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.authorId == userPath(request.auth.uid);
    }

    match /course_comments/{commentId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.authorId == userPath(request.auth.uid);
    }

    match /prayers/{prayerId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if adminOnly() || resource.data.userId == userPath(request.auth.uid);
    }

    match /private_prayers/{prayerId} {
      allow read: if signedIn()
        && (resource.data.userId == userPath(request.auth.uid)
          || hasPermission('manage_private_prayers'));
      allow create: if trustedUser()
        && request.resource.data.userId == userPath(request.auth.uid);
      allow update, delete: if hasPermission('manage_private_prayers')
        || resource.data.userId == userPath(request.auth.uid);
    }

    match /profileFields/{fieldId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_profile_fields');
    }

    match /profileFieldResponses/{responseId} {
      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || hasPermission('manage_profile_fields'));
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && (resource.data.userId == request.auth.uid || hasPermission('manage_profile_fields'));
      allow delete: if hasPermission('manage_profile_fields');
    }

    match /pageContent/{pageId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_pages');
    }

    match /announcements/{announcementId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_announcements');
    }

    match /homeScreenSections/{sectionId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_home_sections');
    }

    match /videos/{videoId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_videos');
    }

    match /videoSections/{sectionId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_videos');
    }

    match /churchLocations/{locationId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_cults') || hasPermission('manage_pages');
    }

    match /cults/{cultId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_cults');
    }

    match /services/{serviceId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_cults');
    }

    match /time_slots/{slotId} {
      allow read: if trustedUser();
      allow write: if hasPermission('manage_cults') || hasPermission('view_schedule_stats');
    }

    match /available_roles/{roleId} {
      allow read: if trustedUser();
      allow write: if hasPermission('manage_cults') || hasPermission('view_schedule_stats');
    }

    match /work_assignments/{assignmentId} {
      allow read: if trustedUser();
      allow write: if hasPermission('manage_cults') || hasPermission('view_schedule_stats');
    }

    match /work_invites/{inviteId} {
      allow read: if trustedUser();
      allow create, update: if trustedUser();
      allow delete: if hasPermission('manage_cults') || hasPermission('view_schedule_stats');
    }

    match /work_schedules/{scheduleId} {
      allow read: if trustedUser();
      allow write: if hasPermission('manage_cults') || hasPermission('view_schedule_stats');
    }

    match /ministry_events/{eventId} {
      allow read: if publicRead();
      allow write: if hasPermission('create_ministry') || hasPermission('manage_event_attendance');
    }

    match /group_events/{eventId} {
      allow read: if publicRead();
      allow write: if hasPermission('create_group') || hasPermission('manage_event_attendance');
    }

    match /event_attendees/{attendeeId} {
      allow read: if publicRead();
      allow create: if trustedUser();
      allow update, delete: if hasPermission('manage_event_attendance');
    }

    match /event_reminders/{reminderId} {
      allow read: if trustedUser()
        && resource.data.userId == userPath(request.auth.uid);
      allow create: if trustedUser()
        && request.resource.data.userId == userPath(request.auth.uid);
      allow update, delete: if trustedUser()
        && resource.data.userId == userPath(request.auth.uid);
    }

    match /event_attendance/{attendanceId} {
      allow read: if hasPermission('manage_event_attendance') || hasPermission('view_group_stats') || hasPermission('view_ministry_stats');
      allow write: if hasPermission('manage_event_attendance');
    }

    match /families/{familyId} {
      allow read: if trustedUser();
      allow write: if adminOnly();
    }

    match /family_groups/{familyId} {
      allow read: if trustedUser();
      allow write: if adminOnly();
    }

    match /children/{childId} {
      allow read, write: if adminOnly();
    }

    match /scheduledRooms/{roomId} {
      allow read: if trustedUser();
      allow write: if adminOnly();
    }

    match /courses/{courseId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_pages');
    }

    match /course_modules/{moduleId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_pages');
    }

    match /course_lessons/{lessonId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_pages');
    }

    match /user_course_progress/{progressId} {
      allow read, write: if trustedUser();
    }

    match /saved_locations/{locationId} {
      allow read, write: if trustedUser();
    }

    match /locations/{locationId} {
      allow read: if publicRead();
      allow write: if trustedUser();
    }

    match /eventCategories/{categoryId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_event_attendance') || hasPermission('manage_cults');
    }

    match /ministry_roles/{roleId} {
      allow read: if trustedUser();
      allow write: if hasPermission('create_ministry') || hasPermission('manage_cults');
    }

    match /cult_ministries/{docId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_cults');
    }

    match /cult_songs/{songId} {
      allow read: if publicRead();
      allow write: if hasPermission('manage_cults');
    }

    match /predefined_messages/{messageId} {
      allow read: if trustedUser();
      allow write: if hasPermission('manage_private_prayers');
    }

    match /pastor_availability/{availabilityId} {
      allow read: if trustedUser();
      allow write: if hasPermission('manage_counseling_availability');
    }

    match /counseling_appointments/{appointmentId} {
      allow read, create: if trustedUser();
      allow update, delete: if hasPermission('manage_counseling_requests');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}