rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function trustedUser() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isPdf() {
      return request.resource != null
        && request.resource.contentType == 'application/pdf';
    }

    function isAudio() {
      return request.resource != null
        && request.resource.contentType.matches('audio/.*');
    }

    function belowMb(mb) {
      return request.resource != null
        && request.resource.size < mb * 1024 * 1024;
    }

    function hasAdminClaim() {
      return signedIn()
        && (request.auth.token.admin == true
          || request.auth.token.superUser == true
          || request.auth.token.isSuperUser == true);
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /app_config/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(3);
    }

    match /donation_section_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /live_stream_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /announcements/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /announcement_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /events/{eventId}/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /event_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /group_events/{groupId}/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /ministry_events/{ministryId}/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /ministry_events/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /posts/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && belowMb(5);
    }

    match /group_posts/{groupId}/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(userId) && isImage() && belowMb(5);
    }

    match /group_posts/{groupId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /group_posts/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /ministry_posts/{ministryId}/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if isOwner(userId) && isImage() && belowMb(5);
    }

    match /ministry_posts/{ministryId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /ministry_posts/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /group_chats/{groupId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser()
        && ((isImage() && belowMb(5)) || (isPdf() && belowMb(10)) || (isAudio() && belowMb(25)));
    }

    match /ministry_chats/{ministryId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser()
        && ((isImage() && belowMb(5)) || (isPdf() && belowMb(10)) || (isAudio() && belowMb(25)));
    }

    match /user_images/{userIdFileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(3);
    }

    match /profile_images/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && belowMb(3);
    }

    match /group_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /ministry_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /family_groups/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /family_images/{familyId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /children/{childId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(3);
    }

    match /guardians/{guardianId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(3);
    }

    match /visitors/{visitorId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser() && isImage() && belowMb(3);
    }

    match /page_content_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /page_card_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(3);
    }

    match /lesson_materials/{courseId}/{lessonId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser()
        && ((isImage() && belowMb(5)) || (isPdf() && belowMb(20)));
    }

    match /courses/{courseId}/lessons/{lessonId}/materials/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser()
        && ((isImage() && belowMb(5)) || (isPdf() && belowMb(25)));
    }

    match /courses/{courseId}/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /course_images/{fileName} {
      allow read: if true;
      allow write: if trustedUser() && isImage() && belowMb(5);
    }

    match /cult_songs/{songId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser()
        && ((isAudio() && belowMb(25)) || (isPdf() && belowMb(10)));
    }

    match /cult_songs/{cultId}/{songId}/{fileName} {
      allow read: if signedIn();
      allow write: if trustedUser()
        && ((isAudio() && belowMb(25)) || (isPdf() && belowMb(10)));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
